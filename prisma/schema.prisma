// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id       String  @id @default(cuid())
  category String  @unique
  users    User[]  @relation("UserCategory")

  @@map("categories")
}

model User {
  id          String   @id @default(cuid())
  name        String
  userTypeId  String   @map("user_type_id")
  userType    Category @relation("UserCategory", fields: [userTypeId], references: [id], onDelete: Cascade)
  
  @@map("users")
}

model Zapis {
  id        String    @id @default(cuid())
  number    Int
  name      String
  trans     String
  srokDost  DateTime? @map("srok_dost")
  datObr    DateTime? @map("dat_obr")
  timObr    String?   @map("tim_obr")
  datRazm   DateTime? @map("dat_razm")
  timRazm   String?   @map("tim_razm")
  telephon  String?   @map("telephon")
  zvonok    String?   @map("zvonok")

  @@index([name])
  @@map("zapis")
}
